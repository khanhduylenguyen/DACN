# ============================================
# AWS S3 Configuration (tùy chọn - chỉ dùng khi muốn upload file)
# ============================================
# Bật/Tắt tính năng upload lên S3 (true/false)
AWS_S3_ENABLED=true

# AWS Region (gần user nhất để tiết kiệm latency & chi phí)
# ap-southeast-1 (Singapore) - khuyến nghị cho VN
# us-east-1 (N. Virginia) - rẻ nhất
AWS_REGION=ap-southeast-1

# S3 Bucket name (PHẢI là unique toàn cầu, vd: medi-path-ease-<your-name>-2026)
AWS_S3_BUCKET=medi-path-ease-uploads

# Access key ID (tạo trong IAM → Users → Access keys)
AWS_ACCESS_KEY_ID=your-access-key-id-here

# Secret access key (chỉ hiện 1 lần khi tạo)
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# Số giây presigned URL có hiệu lực (mặc định 3600 = 1 giờ)
AWS_S3_SIGNED_URL_EXPIRES=3600

# Giới hạn dung lượng file tối đa (bytes) - mặc định 10MB
UPLOAD_MAX_FILE_SIZE=10485760

# Loại file được phép (phân cách bằng dấu phẩy)
UPLOAD_ALLOWED_MIME=application/pdf,image/jpeg,image/png,image/webp
