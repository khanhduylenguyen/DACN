# ============================================
# MongoDB
# ============================================
MONGO_ROOT_USER=mediadmin
MONGO_ROOT_PASSWORD=change-this-to-a-secure-password
MONGODB_DATABASE=medi-path-ease
MONGODB_PORT=27017

# ============================================
# Backend
# ============================================
PORT=3001
NODE_ENV=production

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=change-this-to-a-very-secure-random-string-minimum-32-characters
JWT_EXPIRES_IN=7d

# ============================================
# AWS Configuration
# ============================================
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=medi-path-ease-uploads

# ============================================
# EmailJS (for notifications)
# ============================================
EMAILJS_SERVICE_ID=your-emailjs-service-id
EMAILJS_TEMPLATE_ID=your-emailjs-template-id
EMAILJS_PUBLIC_KEY=your-emailjs-public-key

# ============================================
# Frontend URL (for CORS)
# ============================================
FRONTEND_URL=https://mediathease.com

# ============================================
# Redis (Optional)
# ============================================
REDIS_PORT=6379
REDIS_HOST=localhost

# ============================================
# Vite (Frontend)
# ============================================
VITE_PORT=5173
VITE_API_URL=https://api.medipathease.com
VITE_API_BASE_URL=/api
